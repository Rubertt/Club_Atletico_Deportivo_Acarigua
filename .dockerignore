# Control de versiones
.git
.gitignore
.gitattributes

# Dependencias (se instalan dentro del contenedor)
vendor/
node_modules/

# Entornos
.env
.env.*
!.env.example

# Logs y caché (se regeneran)
storage/logs/*
!storage/logs/.gitkeep
storage/cache/*
!storage/cache/.gitkeep

# Uploads de desarrollo (los sube el usuario final)
public/assets/uploads/**/*
!public/assets/uploads/**/.gitkeep

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# Tests / docs locales
tests/tmp/
*.log
phpunit.result.cache

# Docker meta-archivos (el Dockerfile sí necesita la carpeta docker/)
docker-compose.yml
docker-compose.*.yml
.dockerignore
