# ===========================================================================
# Variables opcionales para docker-compose
#
# Este archivo es SEPARADO del .env del proyecto (que es para PHP sin Docker).
#
# Para usar valores personalizados:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up -d
#
# Todas las variables tienen el prefijo CADA_ para no colisionar con el .env
# del proyecto (APP_URL, DB_USER, etc. del PHP local).
# ===========================================================================

# Puertos expuestos al host (cambia si 8080/3307/8081 ya están en uso)
CADA_APP_HOST_PORT=8080
CADA_DB_HOST_PORT=3307
CADA_PMA_HOST_PORT=8081

# URL pública (debe incluir puerto si no es 80)
CADA_APP_URL=http://localhost:8080
CADA_APP_ENV=production
CADA_APP_DEBUG=false

# Base de datos del stack
CADA_DB_NAME=club_atletico_db_normalized
CADA_DB_USER=cada_user
CADA_DB_PASSWORD=cada_pass_2026
CADA_DB_ROOT_PASSWORD=cada_root_2026

# Clave JWT — GENERAR para producción:
#   php -r "echo bin2hex(random_bytes(32));"
CADA_JWT_SECRET=change_me_to_64_hex_chars_in_production

# Credenciales del admin inicial (primera ejecución)
CADA_ADMIN_EMAIL=admin@cada.com
CADA_ADMIN_PASSWORD=Admin2026!
