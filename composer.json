{
    "name": "cada/club-atletico-deportivo-acarigua",
    "description": "Sistema de gestión deportiva del Club Atlético Deportivo Acarigua",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-gd": "*",
        "vlucas/phpdotenv": "^5.6",
        "tecnickcom/tcpdf": "^6.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php",
            "app/Helpers/constants.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "install-db": "php database/install.php",
        "serve": "php -S localhost:8000 -t public"
    }
}
